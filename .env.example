# Telegram Bot Configuration
# Get your token from @BotFather on Telegram
TELEGRAM_TOKEN=your_telegram_bot_token_here

# Tender Indonesia Account
# Register at https://tender-indonesia.com/registrasi/
TENDER_USER=your_tender_username_here
TENDER_PASS=your_tender_password_here

# Optional: Tesseract path (only needed if not in system PATH)
# TESSERACT_CMD=/usr/bin/tesseract  # Linux/Mac
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe  # Windows
